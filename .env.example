# Copy to .env and fill with the same Neon credentials used by solaris-api.
# DATABASE_URL must start with jdbc:postgresql://

DATABASE_URL=jdbc:postgresql://YOUR-NEON-HOST/neondb?sslmode=require
DATABASE_USERNAME=your_neon_user
DATABASE_PASSWORD=your_neon_password

PORT=8081
RESEND_API_KEY=
EMAIL_FROM=no-reply@solarismanager.com
BILLING_PORTAL_URL=http://localhost:8081
